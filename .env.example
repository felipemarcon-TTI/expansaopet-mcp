# Bling OAuth (obter em: Bling > Configurações > Integrações > API)
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=

# Obtido após autenticar via /bling/auth (tela de sucesso mostra o valor)
BLING_REFRESH_TOKEN=

# Token Bearer para autenticar no MCP (gere um valor aleatório seguro)
MCP_AUTH_TOKEN=

# Usuários adicionais com permissão limitada (opcional)
# MCP_USERS=[{"id":"leitura","token":"seu_token","role":"read"}]

# Setado automaticamente pelo Railway — não alterar
# PORT=8000
# RAILWAY_PUBLIC_DOMAIN=
